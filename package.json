{
  "name": "forest-shuffle-scoring",
  "private": true,
  "version": "0.5.0",
  "homepage": "https://soldag.github.io/forest-shuffle-scoring",
  "type": "module",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24"
    },
    "packageManager": {
      "name": "npm",
      "version": "^11"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint --max-warnings=0 --fix .",
    "preview": "vite preview",
    "format": "prettier --write '**/*.{js,jsx,cjs,ts,tsx,css,md,json}'",
    "format:check": "prettier --check '**/*.{js,jsx,cjs,ts,tsx,css,md,json}'",
    "i18n:extract": "formatjs extract 'src/**/*.{js,jsx,ts,tsx}' --ignore 'src/types/**' --out-file messages.json && formatjs compile messages.json --out-file src/translations/en.json && rm messages.json",
    "i18n:check": "tsx scripts/checkTranslations.ts",
    "manifests:generate": "tsx scripts/generateManifests.ts",
    "manifests:check": "tsx scripts/generateManifests.ts --check",
    "test": "jest --coverage --coverageReporters=html",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/joy": "^5.0.0-beta.52",
    "@types/lodash-es": "^4.17.12",
    "@types/pako": "^2.0.4",
    "immer": "^11.1.4",
    "lodash-es": "^4.18.1",
    "pako": "^2.1.0",
    "qr-code-styling": "^1.9.2",
    "qr-scanner": "^1.4.2",
    "react": "^19.2.4",
    "react-countup": "^6.5.3",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "^7.72.1",
    "react-intl": "^10.1.1",
    "tinycolor2": "^1.6.0",
    "url-join": "^5.0.0",
    "usehooks-ts": "^3.1.1",
    "uuid": "^13.0.0",
    "wouter": "^3.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@formatjs/cli": "^6.14.1",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/addon-links": "^10.3.4",
    "@storybook/addon-themes": "^10.3.4",
    "@storybook/react-vite": "^10.3.4",
    "@swc/core": "^1.15.21",
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/tinycolor2": "^1.4.6",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "colors": "^1.4.0",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.3.4",
    "glob": "^13.0.6",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.8.1",
    "storybook": "^10.3.4",
    "storybook-react-intl": "^10.1.1",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "type-fest": "^5.5.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.1.3",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-window": "^7.4.0"
  },
  "overrides": {
    "storybook-react-intl": {
      "react-intl": "$react-intl"
    },
    "serialize-javascript": "^7.0.3"
  }
}
